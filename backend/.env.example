# PostgreSQL Connection URL
# Local Development: postgresql://<username>:<password>@localhost:5432/<dbname>?sslmode=prefer
# Deployed (Neon/Supabase/Render): postgresql://<user>:<password>@<host>:5432/<dbname>?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/nexoradb?sslmode=prefer"

# Used to sign JWT auth tokens - change this to any long random string
JWT_SECRET="nexora-dev-secret-change-me"

# Server port
PORT=4000

# Optional: without this, AI Chat / Insight narratives / Automation drafts
# fall back to deterministic, template-based reasoning (no hallucination,
# fully functional). Add a key to upgrade chat + narrative copy to Gemini.
GEMINI_API_KEY=

# CORS origin for the frontend
CLIENT_ORIGIN="http://localhost:3000"

# Google OAuth Client ID (obtain from Google Cloud Console -> APIs & Services -> Credentials)
# Setup Steps:
# 1. Go to Google Cloud Console (https://console.cloud.google.com)
# 2. Create or select a project.
# 3. Go to "APIs & Services" -> "OAuth consent screen", set User Type to External, and fill in app details.
# 4. Go to "Credentials" -> "Create Credentials" -> "OAuth client ID".
# 5. Select Application type: "Web application".
# 6. Add Authorized JavaScript origins:
#    - http://localhost:3000
#    - https://<your-vercel-domain>.vercel.app
# 7. Add Authorized redirect URIs:
#    - http://localhost:3000
#    - https://<your-vercel-domain>.vercel.app
# 8. Copy the generated Client ID and paste it here and in frontend/.env.local
GOOGLE_CLIENT_ID=

